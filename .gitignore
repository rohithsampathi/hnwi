# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/.next.stale*/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test output artifacts (generated, not source)
__tests__/pdf/screenshots/
__tests__/pdf/*.pdf
__tests__/pdf/*.png

# debug/utility scripts (not needed in production)
scripts/debug-*.ts
scripts/check-*.ts

# streamlit files (local development only)
*.py
requirements.txt
requirements-dev.txt
__pycache__/
*.pyc
.streamlit/
streamlit_app.py
pages/*.py
.env.streamlit
